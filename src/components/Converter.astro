---
interface Props {
	title: string;
	fromLabel: string;
	toLabel: string;
	converterId: string;
}

const { title, fromLabel, toLabel, converterId } = Astro.props;
---

<article class="converter" data-converter-id={converterId}>
	<h1>{title}</h1>
	<form id={converterId} class="converter-form">
		<div class="field">
			<label for="input">{fromLabel}</label>
			<textarea id="input" name="input" rows="5" placeholder="Enter data..."></textarea>
		</div>
		<div class="field">
			<label for="output">{toLabel}</label>
			<textarea id="output" name="output" rows="5" readonly placeholder="Result..."></textarea>
		</div>
		<button type="submit">Convert</button>
	</form>
</article>

<style>
	.converter h1 {
		font-size: 1.75rem;
		font-weight: 600;
		margin: 0 0 1.5rem;
		letter-spacing: -0.02em;
	}

	.converter-form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.field label {
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--text-muted);
	}

	textarea {
		width: 100%;
		padding: 1rem 1.25rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
		resize: vertical;
		transition: border-color 0.2s;
	}

	textarea:focus {
		outline: none;
		border-color: var(--accent);
	}

	textarea::placeholder {
		color: var(--text-muted);
		opacity: 0.7;
	}

	textarea[readonly] {
		opacity: 0.95;
		cursor: default;
	}

	button {
		align-self: flex-start;
		padding: 0.75rem 1.5rem;
		background: var(--accent);
		color: white;
		border: none;
		border-radius: 8px;
		font-family: inherit;
		font-size: 0.95rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s;
	}

	button:hover {
		background: var(--accent-hover);
	}
</style>
